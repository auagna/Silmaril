# Supabase
# Create a project at https://supabase.com and copy values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only. NEVER expose to the client. Only used by server actions / route handlers
# that intentionally bypass RLS (e.g. seed scripts).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
